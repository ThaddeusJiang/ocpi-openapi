{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest"]
  },
  "include": ["openapi-ts.config.ts", "src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
